# PostgreSQL
DATABASE_URL=postgresql+asyncpg://csa:password@postgres:5432/csa_platform

# Redis
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_PASSWORD=change_me_redis_pass_here

# JWT
JWT_SECRET=generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# HMAC Serial System
SERIAL_SECRET=generate_with_openssl_rand_hex_32

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@csa.gov.gh
SMTP_PASSWORD=smtp_password
SMTP_FROM_NAME=CSA Cyber Platform

# MinIO / S3
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=csa-reports

# HIBP
HIBP_API_URL=https://haveibeenpwned.com/api/v3/breachedaccount
HIBP_API_KEY=your_hibp_api_key_here

# Platform URLs
DOMAIN=YOUR_ORACLE_IP
FRONTEND_URL=http://YOUR_ORACLE_IP
API_URL=http://YOUR_ORACLE_IP
TRACKING_BASE_URL=http://YOUR_ORACLE_IP

# Celery
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0
# CELERY_REDIS_PASSWORD=change_me (optional)

# Infrastructure
CLOUDFLARE_TUNNEL_TOKEN=your_token_here

# Admin seed
SEED_ADMIN_EMAIL=admin@csa.gov.gh
SEED_ADMIN_PASSWORD=change_me

# Frontend
NEXT_PUBLIC_API_URL=http://YOUR_ORACLE_IP/api/v1
NEXT_PUBLIC_SOCKET_URL=http://YOUR_ORACLE_IP
