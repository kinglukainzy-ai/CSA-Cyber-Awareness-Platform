# PostgreSQL
DATABASE_URL=postgresql+asyncpg://csa:password@postgres:5432/csa_platform

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change_me_in_production_very_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# HMAC Serial System
SERIAL_SECRET=another_long_secret_for_flag_generation

# Email (SMTP relay)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@csa.gov.gh
SMTP_PASSWORD=smtp_password
SMTP_FROM_NAME=CSA Cyber Platform

# MinIO / S3
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=csa-reports

# HIBP (breach checker — no key needed for k-anonymity)
HIBP_API_URL=https://api.pwnedpasswords.com/range

# Platform URLs
FRONTEND_URL=https://platform.csa.gov.gh
API_URL=https://api.platform.csa.gov.gh
TRACKING_BASE_URL=https://track.platform.csa.gov.gh

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Admin seed (used by initial migration seeder)
SEED_ADMIN_EMAIL=admin@csa.gov.gh
SEED_ADMIN_PASSWORD=change_me_immediately

# Frontend
NEXT_PUBLIC_API_URL=https://api.platform.csa.gov.gh/api/v1
NEXT_PUBLIC_SOCKET_URL=https://api.platform.csa.gov.gh
